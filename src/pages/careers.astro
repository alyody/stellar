---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Careers | FS Me Logistics" description="Join the elite team at FS Me Logistics. Explore open positions in global trade and fleet management.">
	<section class="relative py-32 overflow-hidden">
		<div class="container mx-auto px-6 relative z-10">
			<div class="max-w-4xl">
				<h1 class="text-xs font-bold uppercase tracking-[0.6em] text-crimson mb-8">Human Capital</h1>
				<h2 class="text-5xl md:text-7xl text-navy leading-tight mb-12 font-black">
					Join the <span class="italic text-crimson">Elite</span> <br />Logistics Force.
				</h2>
				<p class="text-xl text-slate-600 max-w-2xl mb-16 font-medium leading-relaxed">
					At FS Me Logistics, we don't just move cargo—we manage the variables that define global trade. We are looking for high-caliber professionals to join our regional operations.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-32">
				<div class="glass-card p-10 bg-slate-50 border-none">
					<div class="text-crimson font-black text-4xl mb-6">01</div>
					<h3 class="text-xl font-bold text-navy mb-4 uppercase tracking-tight">Regional Mastery</h3>
					<p class="text-slate-500 text-sm leading-relaxed">We operate in the world's most complex corridors. Our team possesses deep intelligence on Middle East trade lanes.</p>
				</div>
				<div class="glass-card p-10 bg-slate-50 border-none">
					<div class="text-crimson font-black text-4xl mb-6">02</div>
					<h3 class="text-xl font-bold text-navy mb-4 uppercase tracking-tight">Precision Culture</h3>
					<p class="text-slate-500 text-sm leading-relaxed">Error is not an option. We foster a culture of regulatory perfection and flawless commercial documentation.</p>
				</div>
				<div class="glass-card p-10 bg-slate-50 border-none">
					<div class="text-crimson font-black text-4xl mb-6">03</div>
					<h3 class="text-xl font-bold text-navy mb-4 uppercase tracking-tight">Elite Growth</h3>
					<p class="text-slate-500 text-sm leading-relaxed">Work alongside CONUS-experienced leadership and build a career at the intersection of tech and global trade.</p>
				</div>
			</div>

			<!-- Open Positions -->
			<div class="border-t border-slate-200 pt-20">
				<div class="flex flex-col md:flex-row justify-between items-baseline mb-16">
					<h3 class="text-4xl text-navy font-black uppercase tracking-tight">Open Strategic Positions</h3>
					<p class="text-slate-400 font-bold text-xs tracking-widest uppercase mt-4 md:mt-0">Updated: Q1 2026</p>
				</div>

				<div class="space-y-4">
					<div class="group glass-card p-8 flex flex-col md:flex-row justify-between items-center hover:bg-navy transition-all duration-500 cursor-pointer">
						<div class="text-left">
							<span class="text-[10px] font-bold uppercase tracking-widest text-crimson mb-2 block">Operations</span>
							<h4 class="text-xl font-black text-navy group-hover:text-white transition-colors uppercase tracking-tight">Logistics Coordinator</h4>
						</div>
						<div class="flex items-center gap-8 mt-6 md:mt-0">
							<span class="text-slate-400 text-xs font-bold uppercase tracking-widest group-hover:text-slate-400">Dubai, UAE</span>
							<div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center group-hover:border-crimson group-hover:bg-crimson transition-all">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-navy group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
								</svg>
							</div>
						</div>
					</div>

					<div class="group glass-card p-8 flex flex-col md:flex-row justify-between items-center hover:bg-navy transition-all duration-500 cursor-pointer">
						<div class="text-left">
							<span class="text-[10px] font-bold uppercase tracking-widest text-crimson mb-2 block">Fleet Management</span>
							<h4 class="text-xl font-black text-navy group-hover:text-white transition-colors uppercase tracking-tight">Fleet Operations Manager</h4>
						</div>
						<div class="flex items-center gap-8 mt-6 md:mt-0">
							<span class="text-slate-400 text-xs font-bold uppercase tracking-widest group-hover:text-slate-400">Jeddah, KSA</span>
							<div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center group-hover:border-crimson group-hover:bg-crimson transition-all">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-navy group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
								</svg>
							</div>
						</div>
					</div>
				</div>

				<div class="mt-20 text-center glass-card p-16 border-dashed border-2 border-slate-200">
					<h4 class="text-2xl text-navy font-black mb-6 uppercase tracking-tight">Don't see your role?</h4>
					<p class="text-slate-500 mb-10 max-w-xl mx-auto">We are always looking for exceptional talent in trade compliance, supply chain engineering, and regional logistics management.</p>
					<a href="mailto:stellar.hr@stellarfz.me" class="btn-primary inline-block">Send General Application</a>
					<p class="mt-6 text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em]">Contact: stellar.hr@stellarfz.me</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
