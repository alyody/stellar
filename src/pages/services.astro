---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | Stellar Logistics">
	<section class="bg-navy py-24 px-6 text-white overflow-hidden relative">
		<div class="absolute inset-0 opacity-10">
			<svg viewBox="0 0 100 100" preserveAspectRatio="none" class="w-full h-full">
				<path d="M0 0 L100 0 L100 100 L0 100 Z" fill="url(#grid)"></path>
				<defs>
					<pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
						<path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5"/>
					</pattern>
				</defs>
			</svg>
		</div>

		<div class="container mx-auto relative z-10 text-center">
			<h1 class="text-xs font-bold uppercase tracking-[0.6em] text-crimson mb-6">Expertise & Operations</h1>
			<h2 class="text-4xl md:text-6xl max-w-4xl mx-auto leading-tight">Global Logistics Management for <span class="italic text-slate-300">High-Stakes Trade</span></h2>
		</div>
	</section>

	<section class="py-24 px-6">
		<div class="container mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center mb-32">
				<div>
					<div class="inline-block bg-navy p-3 rounded-2xl mb-8">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
						</svg>
					</div>
					<h3 class="text-3xl md:text-4xl text-navy mb-8">Trade Route Management</h3>
					<div class="space-y-6 text-slate-600 leading-relaxed text-lg">
						<p>
							Specialized management of <strong>Middle East / Persian Gulf / Red Sea to CONUS</strong> trade routes. We provide end-to-end oversight for complex logistical corridors.
						</p>
						<p>
							Our team specializes in intra-Middle East sectors, ensuring seamless coordination corresponding to local trade management requirements.
						</p>
						<ul class="space-y-4 pt-4">
							<li class="flex items-start gap-3">
								<span class="text-crimson font-bold text-xl">•</span>
								<span>Adherence to regional shipping protocols</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-crimson font-bold text-xl">•</span>
								<span>Direct coordination with Shippers and Consignees</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="text-crimson font-bold text-xl">•</span>
								<span>Red Sea transit risk mitigation and reporting</span>
							</li>
						</ul>
					</div>
				</div>
				<div class="bg-slate-100 rounded-[3rem] p-4">
					<div class="bg-navy rounded-[2.5rem] p-12 aspect-square flex flex-col justify-between overflow-hidden relative group">
						<img src="/vessel_3.jpg" alt="Vessel Operations" class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:scale-110 transition-transform duration-1000" />
						<div class="absolute inset-0 bg-gradient-to-br from-crimson/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						<div class="relative z-10">
							<div class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-400 mb-4">Strategic Sector</div>
							<div class="text-6xl text-white font-black italic opacity-20">MIDDLE<br />EAST</div>
						</div>
						<div class="mt-auto relative z-10">
							<div class="text-crimson font-bold text-4xl mb-2">99.8%</div>
							<div class="text-white font-bold opacity-60">Route Efficiency Rating</div>
						</div>
					</div>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="glass-card p-12 hover:border-crimson transition-all border-slate-200">
					<h3 class="text-2xl text-navy mb-6">Commercial Documentation</h3>
					<p class="text-slate-600 mb-8 leading-relaxed">
						Advanced <strong>EDI transactions</strong> processed within local time zones. We support all documentation requirements required for coordinating with your agents, sub-contractors, and freight forwarders.
					</p>
					<div class="flex flex-wrap gap-2">
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Bill of Lading</span>
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Customs Manifests</span>
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">EDI Integration</span>
					</div>
				</div>
				<div class="glass-card p-12 hover:border-crimson transition-all border-slate-200">
					<h3 class="text-2xl text-navy mb-6">Regulatory Reporting</h3>
					<p class="text-slate-600 mb-8 leading-relaxed">
						Regional experts in ensuring your customers' cargo is <strong>monitored, tracked, and reported</strong> as per strict regulatory requirements of the Middle East and Persian Gulf.
					</p>
					<div class="flex flex-wrap gap-2">
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Compliance Auditing</span>
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Real-time Monitoring</span>
						<span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">Legal Filing</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
