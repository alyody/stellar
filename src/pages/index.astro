---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home | Stellar Logistics">
	<!-- Hero Section -->
	<section class="relative h-[85vh] min-h-[600px] overflow-hidden flex items-center">
		<!-- Background Image -->
		<div class="absolute inset-0 z-0">
			<img src="/hero_background.jpg" alt="Stellar Logistics Cargo Vessel" class="w-full h-full object-cover" />
			<div class="absolute inset-0 bg-navy/60 backdrop-blur-[2px]"></div>
		</div>
		
		<div class="container mx-auto px-6 relative z-10">
			<div class="max-w-3xl">
				<div class="inline-flex items-center gap-2 bg-crimson/20 border border-crimson/30 rounded-full px-4 py-1.5 mb-8 animate-fade-in">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-crimson opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-crimson"></span>
					</span>
					<span class="text-white text-[10px] font-bold uppercase tracking-[0.2em]">Next-Gen Trade Operations</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl lg:text-8xl text-white leading-[1.05] mb-8 drop-shadow-2xl">
					Moving <span class="text-crimson italic">Global</span> Commerce Forward
				</h1>
				
				<p class="text-xl text-slate-200 mb-10 leading-relaxed font-medium max-w-2xl">
					Elite trade management, commercial documentation, and regulatory reporting for the Middle East, Persian Gulf, and Red Sea corridors.
				</p>
				
				<div class="flex flex-wrap gap-4 items-center">
					<a href="/contact" class="btn-primary flex items-center gap-3 group">
						Request a Quote
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:translate-x-1">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
						</svg>
					</a>
					<a href="/services" class="text-white font-bold text-sm uppercase tracking-widest border-b-2 border-white/20 hover:border-crimson transition-all py-1">
						Our Trade Routes
					</a>
				</div>
			</div>
		</div>

		<!-- Cargo Tracking Bar -->
		<div class="absolute bottom-0 left-0 w-full bg-white/10 backdrop-blur-xl border-t border-white/10 py-6 px-6 z-20">
			<div class="container mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
				<div class="flex items-center gap-4">
					<div class="bg-navy p-2 rounded">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
						</svg>
					</div>
					<div>
						<div class="text-[10px] text-slate-300 font-bold uppercase tracking-widest">Active Search</div>
						<div class="text-white font-bold">Track Your Shipment</div>
					</div>
				</div>
				<div class="flex-1 max-w-xl flex items-center gap-2 bg-navy/50 border border-white/10 rounded-full py-1 pr-1 pl-6">
					<input type="text" placeholder="Enter HBL, ContID, or Booking Number..." class="bg-transparent border-none text-white text-sm focus:ring-0 w-full font-medium" />
					<button class="bg-white text-navy font-bold text-sm px-6 py-2 rounded-full hover:bg-crimson hover:text-white transition-all">Search</button>
				</div>
			</div>
		</div>
	</section>

	<!-- Bento Grid Services Section -->
	<section class="py-32 bg-slate-50 relative overflow-hidden">
		<!-- Subtle Accent -->
		<div class="absolute -top-24 -right-24 w-96 h-96 bg-navy/[0.02] rounded-full blur-3xl"></div>
		
		<div class="container mx-auto px-6">
			<div class="text-center mb-20 max-w-3xl mx-auto">
				<h2 class="text-xs font-bold uppercase tracking-[0.4em] text-crimson mb-4">Core Capabilities</h2>
				<h3 class="text-4xl md:text-5xl text-navy">Specialized Solutions for <br /><span class="italic">Elite Logistics</span></h3>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 h-auto md:h-[600px]">
				<!-- Main Service: Trade Route Management -->
				<div class="md:col-span-2 md:row-span-2 group relative overflow-hidden rounded-3xl bg-navy flex flex-col justify-end p-12 text-white">
					<div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/40 to-transparent"></div>
					<!-- Background imagery placeholder -->
					<div class="absolute inset-0 z-0 opacity-40 group-hover:scale-105 transition-transform duration-700">
						<div class="w-full h-full bg-slate-800 flex items-center justify-center opacity-20">
							<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-full h-full p-20 fill-white">
								<path d="M43.3,-50.2C55.5,-44.1,64.2,-30.4,67.1,-15.8C69.9,-1.2,66.9,14.2,59.3,27C51.6,39.8,39.3,49.9,25.4,56.5C11.5,63.1,-4,66.1,-19.7,63.7C-35.4,61.4,-51.2,53.7,-60.8,40.9C-70.3,28,-73.6,10,-69.5,-6.1C-65.4,-22.1,-53.8,-36.2,-40.5,-42.2C-27.2,-48.2,-13.6,-46,2.2,-48.6C18,-51.3,31.1,-56.3,43.3,-50.2Z" transform="translate(100 100)" />
							</svg>
						</div>
					</div>
					
					<div class="relative z-10 max-w-lg">
						<div class="w-16 h-16 bg-crimson rounded-2xl flex items-center justify-center mb-8 shadow-xl">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-white">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
							</svg>
						</div>
						<h4 class="text-3xl font-bold mb-4">Trade Route Management</h4>
						<p class="text-slate-300 mb-8 leading-relaxed">
							Management of Middle East / Persian Gulf / Red Sea to CONUS trade routes. Locally adhering and coordinating with the Shipper or Consignee.
						</p>
						<a href="/services" class="flex items-center gap-3 text-crimson font-bold uppercase tracking-widest text-xs group-hover:gap-5 transition-all">
							Explore Routes <span class="text-xl">→</span>
						</a>
					</div>
				</div>

				<!-- Documentation -->
				<div class="group relative overflow-hidden rounded-3xl bg-white border border-slate-200 p-10 flex flex-col justify-between transition-all hover:border-crimson">
					<div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center text-navy group-hover:bg-navy group-hover:text-white transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
						</svg>
					</div>
					<div>
						<h4 class="text-xl font-bold text-navy mb-3">Commercial Documentation</h4>
						<p class="text-slate-500 text-sm leading-relaxed mb-6">
							Complete EDI transactions and documentation coordination for freight forwarders and agents.
						</p>
					</div>
					<div class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Time-Zone Optimized</div>
				</div>

				<!-- Regulatory -->
				<div class="group relative overflow-hidden rounded-3xl bg-white border border-slate-200 p-10 flex flex-col justify-between transition-all hover:border-crimson">
					<div class="w-12 h-12 bg-navy/5 rounded-xl flex items-center justify-center text-navy group-hover:bg-navy group-hover:text-white transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
						</svg>
					</div>
					<div>
						<h4 class="text-xl font-bold text-navy mb-3">Regulatory Reporting</h4>
						<p class="text-slate-500 text-sm leading-relaxed mb-6">
							Precise regional expertise ensuring your cargo is monitored as per strict regulatory requirements.
						</p>
					</div>
					<div class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">100% Compliance</div>
				</div>
			</div>
		</div>
	</section>

	<style>
		@keyframes fade-in {
			from { opacity: 0; transform: translateY(10px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-fade-in {
			animation: fade-in 1s ease-out forwards;
		}
	</style>
</BaseLayout>
